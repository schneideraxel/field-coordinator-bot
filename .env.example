# .env.example
# Copy this file to .env.local and fill in your values.
# Load before running: set -a && source .env.local && set +a

# ── GitHub App (required) ────────────────────────────────────────────────────

# GitHub App ID (found on the App settings page)
GITHUB_APP_ID=

# Installation ID for the target account/org
GITHUB_INSTALLATION_ID=

# Private key — provide either the inline PEM content or a file path
GITHUB_PRIVATE_KEY=
# GITHUB_PRIVATE_KEY_PATH=secrets/github-app.pem

# ── Workflows ────────────────────────────────────────────────────────────────

# Path to the workflow definitions file (.yaml)
WORKFLOW_FILE=workflows/workflows.yaml

# Root directory prepended to all script paths in run_script tasks (optional)
# R_WORKSPACE_ROOT=/path/to/your/scripts

# ── Scheduler ────────────────────────────────────────────────────────────────

# File where scheduled jobs are persisted across restarts (default: scheduler_jobs.json)
# SCHEDULER_JOBS_FILE=scheduler_jobs.json

# URL of the running API server, used by the CLI schedule/cancel commands
# SCHEDULER_URL=http://127.0.0.1:8000

# ── HTTP server ──────────────────────────────────────────────────────────────

# HOST=0.0.0.0
# PORT=8000
# UVICORN_RELOAD=0

# Secret for verifying GitHub webhook signatures (optional)
# GITHUB_WEBHOOK_SECRET=

# ── HTTP client ──────────────────────────────────────────────────────────────

# HTTP_TIMEOUT=15
# HTTP_RETRIES=5
# HTTP_USER_AGENT=gh-automation/1.0

# ── Concurrency ──────────────────────────────────────────────────────────────

# Maximum concurrent threads for parallel workflows
# MAX_INFLIGHT=8

# ── Logging ──────────────────────────────────────────────────────────────────

# LOG_LEVEL=INFO

# ── GitHub Enterprise (optional) ─────────────────────────────────────────────

# GITHUB_API_BASE=https://api.github.com
# GITHUB_GRAPHQL_URL=https://api.github.com/graphql
